# =====================================================================
#  mud-tool — LOCAL / OFFLINE preset for NATIVE (non-Docker) runs
#  Copy to mud-tool/python-sidecar/.env:
#     cp .env.local.example .env      (Linux/macOS/Git-Bash)
#     copy .env.local.example .env    (Windows cmd)
#
#  This file is read by mudtool-server when run directly (not via
#  docker compose). For Docker mode, use the top-level .env.local.example
#  instead (it sets MUD_OPENAI_BASE_URL=http://ollama:11434/v1).
#  ⚠️  Never commit real secrets. Only *.example files are tracked.
# =====================================================================

# ── Backend: Ollama via OpenAI-compatible endpoint ───────────────────
MUD_AI_BACKEND=cloud
MUD_CLOUD_PROVIDER=openai_compatible
MUD_OPENAI_BASE_URL=http://localhost:11434/v1   # native: Ollama runs on the host
MUD_OPENAI_API_KEY=ollama
MUD_OPENAI_MODEL=qwen3:8b

# ── Reliability guardrails ───────────────────────────────────────────
MUD_PIPELINE_MODE=two_model
MUD_PIPELINE_REVIEWER_MODEL=deepseek-r1:7b
MUD_VISUAL_QA_ENABLED=false
MUD_VISUAL_QA_MODEL=llava:7b
MUD_SKILLS_ENABLED=true
MUD_GUIDELINES_ENABLED=true
MUD_GUIDELINES_EMBED_MODEL=nomic-embed-text:latest
MUD_CONFIDENCE_THRESHOLD=0.6
MUD_MAX_RETRIES=3

# ── Rendering (disable Kroki for air-gap; use local plantuml.jar) ───
MUD_USE_KROKI=false

# ── Server ───────────────────────────────────────────────────────────
MUD_HOST=127.0.0.1
MUD_PORT=8042
