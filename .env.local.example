# =====================================================================
#  MUD_MUT — 100% LOCAL / OFFLINE preset  (recommended default)
#  Copy to `.env`:   cp .env.local.example .env
#  Everything runs on local 7B models via Ollama. No API key, no network.
#  Each sub-tool also reads its own .env (mud-tool/python-sidecar/.env,
#  cpputest-rag/.env); these values are the shared/compose defaults.
# =====================================================================

# ── mud-tool (DESIGN half) ───────────────────────────────────────────
# "Local via Ollama" uses the OpenAI-compatible endpoint Ollama exposes.
MUD_AI_BACKEND=cloud
MUD_CLOUD_PROVIDER=openai_compatible
MUD_OPENAI_BASE_URL=http://ollama:11434/v1     # Docker: compose service name; native → http://localhost:11434/v1
MUD_OPENAI_API_KEY=ollama
MUD_OPENAI_MODEL=qwen3:8b

# Reliability guardrails (the reason 7B output is trustworthy)
MUD_PIPELINE_MODE=two_model
MUD_PIPELINE_REVIEWER_MODEL=deepseek-r1:7b
MUD_VISUAL_QA_ENABLED=false
MUD_VISUAL_QA_MODEL=llava:7b
MUD_SKILLS_ENABLED=true
MUD_GUIDELINES_ENABLED=true
MUD_GUIDELINES_EMBED_MODEL=nomic-embed-text:latest
MUD_CONFIDENCE_THRESHOLD=0.6
MUD_MAX_RETRIES=3

# Render diagrams offline (self-host Kroki, or use local plantuml.jar).
# Public kroki.io reaches the network — disable for a true air-gap:
MUD_USE_KROKI=false

MUD_HOST=127.0.0.1
MUD_PORT=8042

# Alternative fully-native local backend (llama.cpp GGUF, no Ollama):
#   MUD_AI_BACKEND=local
#   MUD_LOCAL_MODEL_PATH=/models/qwen3-8b-instruct.Q4_K_M.gguf
#   MUD_LOCAL_MODEL_N_GPU_LAYERS=-1   # -1 = all on GPU, 0 = CPU only

# ── cpputest-rag (VERIFICATION half) ─────────────────────────────────
OLLAMA_URL=http://localhost:11434/api
EMBED_MODEL=all-minilm:latest
GEN_MODEL=qwen2.5:7b
TOP_K=3
BATCH_SIZE=5
REQUEST_TIMEOUT=900
OLLAMA_GPU_LAYERS=35
OLLAMA_FLASH_ATTENTION=true
PORT=8000
FRONTEND_PORT=3000
