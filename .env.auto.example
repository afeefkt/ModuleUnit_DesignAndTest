# =====================================================================
#  MUD_MUT — AUTO preset: LOCAL primary, cloud API fallback
#  Copy to `.env`:   cp .env.auto.example .env
#  Uses local 7B by default; falls back to a cloud provider for hard
#  cases or when the local backend is unavailable.
#  ⚠️  Put real API keys in your LOCAL .env only — never commit them.
# =====================================================================

# ── mud-tool (DESIGN half) ───────────────────────────────────────────
MUD_AI_BACKEND=auto           # cloud primary + local fallback (see settings.AIBackend)

# Primary/local via Ollama
MUD_OPENAI_BASE_URL=http://localhost:11434/v1
MUD_OPENAI_API_KEY=ollama
MUD_OPENAI_MODEL=qwen3:8b

# Cloud fallback — pick ONE provider and set its key in your private .env
MUD_CLOUD_PROVIDER=deepseek
# MUD_DEEPSEEK_API_KEY=__PUT_YOUR_KEY_IN_LOCAL_ENV_ONLY__
# MUD_DEEPSEEK_MODEL=deepseek-chat
#
# or Anthropic:
# MUD_CLOUD_PROVIDER=anthropic
# MUD_ANTHROPIC_API_KEY=__PUT_YOUR_KEY_IN_LOCAL_ENV_ONLY__
# MUD_ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# Guardrails
MUD_PIPELINE_MODE=two_model
MUD_PIPELINE_REVIEWER_MODEL=deepseek-r1:7b
MUD_SKILLS_ENABLED=true
MUD_GUIDELINES_ENABLED=true
MUD_GUIDELINES_EMBED_MODEL=nomic-embed-text:latest
MUD_USE_KROKI=true
MUD_HOST=127.0.0.1
MUD_PORT=8042

# ── cpputest-rag (VERIFICATION half) ─────────────────────────────────
# The test half is local (Ollama) by default; an API backend is on the
# roadmap (see docs/pipeline.md — backend parity).
OLLAMA_URL=http://localhost:11434/api
EMBED_MODEL=all-minilm:latest
GEN_MODEL=qwen2.5:7b
TOP_K=3
BATCH_SIZE=5
REQUEST_TIMEOUT=900
PORT=8000
FRONTEND_PORT=3000
