# =====================================================================
#  MUD_MUT — full variable reference
#  Do NOT copy this file verbatim as your working config. Instead use a
#  preset:
#     cp .env.local.example .env    # 100% offline (recommended)
#     cp .env.auto.example  .env    # local primary + cloud fallback
#  Each sub-tool ALSO has its own template:
#     mud-tool/python-sidecar/.env.example   (all MUD_* options)
#     cpputest-rag/.env.example              (all cpputest options)
#  ⚠️  Never commit real secrets. Only *.example files are tracked.
# =====================================================================

# ─────────────── mud-tool (DESIGN half) — key options ────────────────
# Backend selection: local | cloud | auto
MUD_AI_BACKEND=cloud
MUD_CLOUD_PROVIDER=openai_compatible      # anthropic | openai_compatible | deepseek
MUD_OPENAI_BASE_URL=http://ollama:11434/v1     # Docker: compose service name; native → http://localhost:11434/v1
MUD_OPENAI_API_KEY=ollama
MUD_OPENAI_MODEL=qwen3:8b

# Native local (llama.cpp GGUF) alternative:
# MUD_AI_BACKEND=local
# MUD_LOCAL_MODEL_PATH=/models/model.Q4_K_M.gguf
# MUD_LOCAL_MODEL_N_GPU_LAYERS=-1

# Reliability guardrails
MUD_PIPELINE_MODE=two_model               # single_pass | multi_pass | two_model_fast | two_model
MUD_PIPELINE_REVIEWER_MODEL=deepseek-r1:7b
MUD_VISUAL_QA_ENABLED=false
MUD_VISUAL_QA_MODEL=llava:7b
MUD_SKILLS_ENABLED=true
MUD_GUIDELINES_ENABLED=true
MUD_GUIDELINES_EMBED_MODEL=nomic-embed-text:latest
MUD_CONFIDENCE_THRESHOLD=0.6
MUD_MAX_RETRIES=3

# Naming conventions (AUTOSAR)
MUD_SWC_NAMING_REGEX=^SWC_[A-Z][A-Za-z0-9_]+$
MUD_RUNNABLE_NAMING_REGEX=^RE_[A-Z][A-Za-z0-9_]+$
MUD_PORT_NAMING_REGEX=^(PP|RP)_[A-Z][A-Za-z0-9_]+$

# Rendering
MUD_USE_KROKI=true                        # false for air-gapped; or use local plantuml.jar
MUD_KROKI_BASE_URL=https://kroki.io

MUD_HOST=127.0.0.1
MUD_PORT=8042

# ─────────────── cpputest-rag (VERIFICATION half) ────────────────────
OLLAMA_URL=http://localhost:11434/api
EMBED_MODEL=all-minilm:latest
GEN_MODEL=qwen2.5:7b
C_PROJECT_DIR=/app/c_projects
TEST_EXAMPLES_DIR=/app/test_examples
OUTPUT_DIR=/app/generated_tests
DATABASE_PATH=/app/data/cpputest.db
MAX_FUNCTIONS_PER_CHUNK=10
TOP_K=3
BATCH_SIZE=5
REQUEST_TIMEOUT=900
PORT=8000
FRONTEND_PORT=3000
HOST=0.0.0.0
LOG_LEVEL=INFO
OLLAMA_GPU_LAYERS=35
OLLAMA_FLASH_ATTENTION=true
