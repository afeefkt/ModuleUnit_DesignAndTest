# ═══════════════════════════════════════════════════════════════
#  MUD Tool — Environment Configuration
#  Copy this file to .env and uncomment the section you want.
#  Only ONE backend section should be active at a time.
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
MUD_HOST=127.0.0.1
MUD_PORT=8042
MUD_DEBUG=false
MUD_LOG_LEVEL=info

# ── AI Generation Settings ───────────────────────────────────────
# How many times to retry if AI output is below confidence threshold
MUD_MAX_RETRIES=3
# Minimum AI confidence to accept output (lower = more permissive)
# Use 0.4 for local models, 0.6 for cloud models
MUD_CONFIDENCE_THRESHOLD=0.6


# ═══════════════════════════════════════════════════════════════
#  BACKEND OPTIONS — Uncomment ONE section below
# ═══════════════════════════════════════════════════════════════


# ── OPTION 1: Anthropic Claude (cloud, best quality) ────────────
# Get key at: https://console.anthropic.com
# MUD_AI_BACKEND=cloud
# MUD_CLOUD_PROVIDER=anthropic
# MUD_ANTHROPIC_API_KEY=sk-ant-your-key-here
# MUD_ANTHROPIC_MODEL=claude-sonnet-4-5-20250514
# MUD_ANTHROPIC_MAX_TOKENS=8192


# ── OPTION 2: Ollama (local, free, easiest) ─────────────────────
# Install: https://ollama.com  then run: ollama pull mistral
# MUD_AI_BACKEND=cloud
# MUD_CLOUD_PROVIDER=openai_compatible
# MUD_OPENAI_BASE_URL=http://localhost:11434/v1
# MUD_OPENAI_API_KEY=ollama
# MUD_OPENAI_MODEL=mistral
# MUD_CONFIDENCE_THRESHOLD=0.4
# MUD_MAX_RETRIES=5
# Recommended models (run: ollama pull <name>):
#   mistral           — 4GB, fast, good quality
#   llama3.1          — 5GB, very good quality
#   phi3:medium       — 8GB, best local quality
#   codellama:13b     — 7GB, good structured JSON output


# ── OPTION 3: LocalAI (local, Docker-based) ─────────────────────
# Install: https://localai.io  (docker run localai/localai)
# Default port: 8080
# MUD_AI_BACKEND=cloud
# MUD_CLOUD_PROVIDER=openai_compatible
# MUD_OPENAI_BASE_URL=http://localhost:8080/v1
# MUD_OPENAI_API_KEY=localai
# MUD_OPENAI_MODEL=mistral-7b-instruct
# MUD_CONFIDENCE_THRESHOLD=0.4
# MUD_MAX_RETRIES=5


# ── OPTION 4: LM Studio (local, GUI app) ────────────────────────
# Install: https://lmstudio.ai  → load a model → Start Local Server
# Default port: 1234
# MUD_AI_BACKEND=cloud
# MUD_CLOUD_PROVIDER=openai_compatible
# MUD_OPENAI_BASE_URL=http://localhost:1234/v1
# MUD_OPENAI_API_KEY=lmstudio
# MUD_OPENAI_MODEL=local-model
# MUD_CONFIDENCE_THRESHOLD=0.4
# MUD_MAX_RETRIES=5


# ── OPTION 5: OpenAI (cloud) ────────────────────────────────────
# Get key at: https://platform.openai.com
# MUD_AI_BACKEND=cloud
# MUD_CLOUD_PROVIDER=openai_compatible
# MUD_OPENAI_BASE_URL=https://api.openai.com/v1
# MUD_OPENAI_API_KEY=sk-your-openai-key-here
# MUD_OPENAI_MODEL=gpt-4o
# MUD_OPENAI_MAX_TOKENS=8192


# ── OPTION 6: Any other OpenAI-compatible API ───────────────────
# Works with: Together.ai, Groq, Mistral AI, Perplexity, Fireworks, etc.
# MUD_AI_BACKEND=cloud
# MUD_CLOUD_PROVIDER=openai_compatible
# MUD_OPENAI_BASE_URL=https://api.together.xyz/v1
# MUD_OPENAI_API_KEY=your-key-here
# MUD_OPENAI_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# MUD_CONFIDENCE_THRESHOLD=0.4


# ── OPTION 7: Built-in llama.cpp (no separate server) ───────────
# Download a GGUF model from: https://huggingface.co/TheBloke
# Example: mistral-7b-instruct-v0.2.Q4_K_M.gguf (~4GB)
# Install extra: pip install -e ".[local-llm]"
# MUD_AI_BACKEND=local
# MUD_LOCAL_MODEL_PATH=C:\models\mistral-7b-instruct-v0.2.Q4_K_M.gguf
# MUD_LOCAL_MODEL_N_GPU_LAYERS=-1
# MUD_LOCAL_MODEL_N_CTX=8192
# MUD_LOCAL_MODEL_N_BATCH=512
# MUD_LOCAL_MODEL_N_THREADS=4
# MUD_CONFIDENCE_THRESHOLD=0.4
# MUD_MAX_RETRIES=5


# ═══════════════════════════════════════════════════════════════
#  AUTOSAR Naming Convention Rules (regex)
#  Change these if your project uses different naming standards
# ═══════════════════════════════════════════════════════════════
MUD_SWC_NAMING_REGEX=^SWC_[A-Z][A-Za-z0-9_]+$
MUD_RUNNABLE_NAMING_REGEX=^RE_[A-Z][A-Za-z0-9_]+$
MUD_PORT_NAMING_REGEX=^(PP|RP)_[A-Z][A-Za-z0-9_]+$
MUD_VALIDATION_STRICT_MODE=false


# ═══════════════════════════════════════════════════════════════
#  DIAGRAM RENDERING (for SVG/PNG export)
# ═══════════════════════════════════════════════════════════════
# Use Kroki.io public API (requires internet, free)
MUD_USE_KROKI=true
MUD_KROKI_BASE_URL=https://kroki.io
# Use local plantuml.jar instead (offline)
# MUD_USE_KROKI=false
# MUD_PLANTUML_JAR_PATH=C:\tools\plantuml.jar
